#ventana de continuo
l=espectro1$SiIV1394
f=espectro1$data
lw1 <- l[which(l>=-100 & l<=-40)]
fw1 <- f[which(l>=-100 & l<=-40)]
lw2 <- l[which(l>=80 & l<=150)]
fw2 <- f[which(l>=80 & l<=150)]
#Signal to Noise Ratio SNR en cada ventana
snw1 <- mean(fw1)/sd(fw1)
snw2 <- mean(fw2)/sd(fw2)
#Ventana de la línea
l0III <- l[which(l>=-40 & l<= 80)]
f0III <- f[which(l>=-40 & l<= 80)]
mod1 <- lm(fw1 ~ lw1)
mod1
mod2 <- lm(fw2 ~ lw2)
mod2
fmod1<- mod1$coefficients[2]*l0III + mod1$coefficients[1]
fmod2<- mod2$coefficients[2]*l0III + mod2$coefficients[1]
cont_mean <- (fmod1+fmod2)/2
lcont <- c(lw1,lw2)
fcont <- c(fw1,fw2)
fmod1_cont<- mod1$coefficients[2]*lcont + mod1$coefficients[1]
fmod2_cont<- mod2$coefficients[2]*lcont + mod2$coefficients[1]
F_cont <-(rowMeans(cbind(fmod1_cont,fmod2_cont)))
disp_cont<-mean(abs(fcont-F_cont))
hist(fcont-F_cont)
F_linea <- f0III-cont_mean
Signal <- sum(F_linea)
Noise <- disp_cont
Signal
Noise
